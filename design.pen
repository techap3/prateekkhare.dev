                          "content": "Designing AI systems people can actually trust",
                          "lineHeight": 1.4,
                          "fontFamily": "Geist",
                          "fontSize": 20,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "yBJ3j",
                          "name": "p1x",
                          "fill": "#111827",
                          "textGrowth": "fixed-width",
                          "width": 640,
                          "content": "Why reliability is a product design problem, not just a model quality problem, once automation reaches operational workflows.",
                          "lineHeight": 1.65,
                          "fontFamily": "Newsreader",
                          "fontSize": 16
                        },
                        {
                          "type": "text",
                          "id": "JiCjt",
                          "name": "post1Ann",
                          "fill": "#6B7280",
                          "content": "// reliability is designed outside the model",
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 13,
                          "fontWeight": "500",
                          "letterSpacing": 0.048
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "Lx2Oy",
                      "name": "post2",
                      "width": 620,
                      "layout": "vertical",
                      "gap": 11,
                      "padding": [
                        0,
                        0,
                        22,
                        10
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "Jtng5",
                          "name": "p2d",
                          "fill": "#6B7280",
                          "content": "02 Feb 2026",
                          "lineHeight": 1.5,
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 13,
                          "fontWeight": "500",
                          "letterSpacing": 0.048
                        },
                        {
                          "type": "text",
                          "id": "vt37g",
                          "name": "p2t",
                          "fill": "#111111",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The product leader's job in a system with too many handoffs",
                          "lineHeight": 1.4,
                          "fontFamily": "Geist",
                          "fontSize": 20,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "BwuaL",
                          "name": "p2x",
                          "fill": "#111827",
                          "textGrowth": "fixed-width",
                          "width": 640,
                          "content": "On reducing coordination cost by changing the operating model before adding more process or more tooling.",
                          "lineHeight": 1.65,
                          "fontFamily": "Newsreader",
                          "fontSize": 16
                        },
                        {
                          "type": "text",
                          "id": "Wd4oI",
                          "name": "post2Ann",
                          "fill": "#6B7280",
                          "content": "// handoffs are where systems reveal themselves",
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 13,
                          "fontWeight": "500",
                          "letterSpacing": 0.048
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "4Pdez",
                      "name": "post3",
                      "width": 620,
                      "layout": "vertical",
                      "gap": 13,
                      "padding": [
                        0,
                        0,
                        24,
                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "5oSj3",
                          "name": "p3d",
                          "fill": "#6B7280",
                          "content": "08 Nov 2025",
                          "lineHeight": 1.5,
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 13,
                          "fontWeight": "500",
                          "letterSpacing": 0.048
                        },
                        {
                          "type": "text",
                          "id": "ozm0D",
                          "name": "p3t",
                          "fill": "#111111",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Metrics are useful until they replace judgment",
                          "lineHeight": 1.4,
                          "fontFamily": "Geist",
                          "fontSize": 20,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "8mbcj",
                          "name": "p3x",
                          "fill": "#111827",
                          "textGrowth": "fixed-width",
                          "width": 640,
                          "content": "A short note on knowing when a dashboard clarifies the system and when it merely narrows what the team is willing to see.",
                          "lineHeight": 1.65,
                          "fontFamily": "Newsreader",
                          "fontSize": 16
                        }
                      ]
                    }
                  ]
