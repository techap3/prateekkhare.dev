                      "content": "03 / ABOUT",
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 13,
                      "fontWeight": "500",
                      "letterSpacing": 0.048
                    },
                    {
                      "type": "text",
                      "id": "DA9X3",
                      "name": "title",
                      "fill": "#111111",
                      "textGrowth": "fixed-width",
                      "width": 720,
                      "content": "I build systems\nfor real-world\ncomplexity",
                      "lineHeight": 1.1,
                      "fontFamily": "Geist",
                      "fontSize": 64,
                      "fontWeight": "700",
                      "letterSpacing": -0.01
                    },
                    {
                      "type": "text",
                      "id": "RaDd3",
                      "name": "sub",
                      "fill": "#111827",
                      "textGrowth": "fixed-width",
                      "width": 640,
                      "content": "My work sits at the intersection of product judgment, engineering empathy, and operational design. I am most useful in spaces where the team needs structure without losing speed.",
                      "lineHeight": 1.65,
                      "fontFamily": "Newsreader",
                      "fontSize": 16
                    },
                    {
                      "type": "text",
                      "id": "pO4Oo",
                      "name": "aboutAnn",
                      "fill": "$color-text-secondary",
                      "content": "// systems > features",
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 13,
                      "fontWeight": "500",
                      "letterSpacing": 0.048
                    },
                    {
                      "type": "rectangle",
                      "id": "So9f2",
                      "name": "aboutSig",
                      "fill": "#E5E7EB",
                      "width": 180,
                      "height": 1
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "P7Ok9",
                  "name": "sec1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 13,
                  "children": [
                    {
                      "type": "text",
                      "id": "BFamx",
                      "name": "s1h",
                      "fill": "$color-text-secondary",
                      "content": "01 / WHO I AM",
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 13,
                      "fontWeight": "500",
                      "letterSpacing": 0.048
                    },
                    {
                      "type": "text",
                      "id": "ecdCg",
                      "name": "s1b",
                      "fill": "#111827",
                      "textGrowth": "fixed-width",
                      "width": 640,
                      "content": "I am a product leader with a systems bias. I care about product strategy, but I care just as much about the operating mechanics that determine whether strategy survives contact with reality.",
                      "lineHeight": 1.65,
                      "fontFamily": "Newsreader",
                      "fontSize": 18
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "WEvD8",
                  "name": "sec2",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 15,
                  "children": [
                    {
                      "type": "text",
                      "id": "7RzWM",
                      "name": "s2h",
                      "fill": "$color-text-secondary",
                      "content": "02 / JOURNEY",
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 13,
                      "fontWeight": "500",
                      "letterSpacing": 0.048
                    },
                    {
                      "type": "text",
                      "id": "BrTjm",
                      "name": "s2b",
                      "fill": "#111827",
                      "textGrowth": "fixed-width",
                      "width": 640,
                      "content": "I started close to engineering, which gave me a respect for implementation detail and system constraints. Over time I moved deeper into product, then into AI-assisted systems, where the boundary between product design, operational design, and governance became impossible to ignore.",
                      "lineHeight": 1.65,
                      "fontFamily": "Newsreader",
                      "fontSize": 18
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "84YSW",
                  "name": "sec3",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 13,
                  "padding": [
                    0,
                    0,
                    0,
                    8
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "5h1AN",
                      "name": "s3h",
                      "fill": "$color-text-secondary",
                      "content": "03 / HOW I THINK",
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 13,
                      "fontWeight": "500",
                      "letterSpacing": 0.048
                    },
                    {
                      "type": "text",
                      "id": "WRhJS",
                      "name": "s3b",
                      "fill": "#111827",
                      "textGrowth": "fixed-width",
                      "width": 620,
                      "content": "I look for leverage in the system, not just the interface. I prefer product mechanisms over promises, operating clarity over process theatre, and metrics that sharpen judgment rather than replace it.",
                      "lineHeight": 1.62,
                      "fontFamily": "Newsreader",
                      "fontSize": 20,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "mkC5q",
                      "name": "thinkAnn",
                      "fill": "#6B7280",
                      "content": "// judgment before dashboard theater",
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 13,
                      "fontWeight": "500",
                      "letterSpacing": 0.048
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "vfxas",
                  "name": "sec4",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 15,
                  "children": [
                    {
                      "type": "text",
                      "id": "NsGbh",
                      "name": "s4h",
                      "fill": "$color-text-secondary",
                      "content": "04 / WHAT I'M EXPLORING",
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 13,
                      "fontWeight": "500",
                      "letterSpacing": 0.048
                    },
                    {
                      "type": "text",
                      "id": "6xGWp",
                      "name": "s4b",
                      "fill": "#111827",
                      "textGrowth": "fixed-width",
                      "width": 640,
                      "content": "I am currently interested in AI product governance, workflow intelligence, and how teams design human oversight into systems before scale forces the issue. The throughline is simple: build products that behave well under pressure.",
                      "lineHeight": 1.65,
                      "fontFamily": "Newsreader",
                      "fontSize": 18
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "BboSG",
                  "name": "cta",
                  "fill": "$color-accent",
                  "textGrowth": "fixed-width",
                  "width": 720,
                  "content": "If you're building products where trust, complexity, and operating reality matter, let's talk. →",
                  "lineHeight": 1.4,
                  "fontFamily": "Geist",
                  "fontSize": 20,
                  "fontWeight": "700"
                },
                {
                  "type": "frame",
                  "id": "eQh7t",
                  "name": "footer",
                  "width": "fill_container",
                  "padding": [
                    22,
                    0,
                    0,
                    0
                  ],
                  "justifyContent": "space_between",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "dkBle",
                      "name": "footName",
                      "fill": "$color-text-primary",
                      "content": "Prateek Khare",
                      "fontFamily": "Geist",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "sJ58S",
                      "name": "footLinks",
                      "fill": "$color-accent",
                      "content": "LinkedIn -> Email -> Resume",
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 13,
                      "fontWeight": "600",
                      "letterSpacing": 0.048
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
